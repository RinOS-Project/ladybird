{
  "$comment": [
    "vcpkg-rinos.json — RinOS dependency manifest (informational)",
    "RinOS builds bypass vcpkg entirely. All external dependencies are either:",
    "  1) Replaced by RinOS-native implementations (rintls, rinicu, aquamarine)",
    "  2) Self-built from vendored sources in libs/ (zlib, png, jpeg, webp, sqlite3)",
    "  3) Excluded from the feature set (Skia, ffmpeg, ANGLE, AVIF, JXL, WOFF2)",
    "  4) Provided by Ladybird's own code (LibXML parser, UnsignedBigInteger)",
    "  5) Kept as vcpkg deps for non-RinOS platforms (fast-float, fmt, simdutf)",
    "",
    "CMake guard: all find_package() calls are wrapped with if(NOT AK_OS_RINOS).",
    "Build path:  scripts/build_iso.sh + scripts/build_apps.sh (no cmake).",
    "See: Documentation/RinOS_Porting.md for the full dependency replacement table."
  ],
  "rinos-dependency-map": {
    "openssl":    "→ rintls (libs/rintls)",
    "curl":       "→ direct socket HTTP/1.1 (RinHTTPTransport)",
    "icu":        "→ rinicu IPC + libunicode (libs/rinicu, libs/libunicode)",
    "skia":       "→ aquamarine 2D engine (libs/aquamarine)",
    "angle":      "→ excluded (no GPU backend)",
    "harfbuzz":   "→ aquamarine TrueType renderer",
    "fontconfig": "→ excluded (RinOS font system)",
    "ffmpeg":     "→ excluded (media=off)",
    "sdl3":       "→ excluded (no display backend needed)",
    "vulkan":     "→ excluded (no GPU backend)",
    "libavif":    "→ excluded (AVIF format unsupported)",
    "libjxl":     "→ excluded (JPEG XL format unsupported)",
    "woff2":      "→ excluded (WOFF2 font unsupported)",
    "libpng":     "→ libs/png (self-built)",
    "libjpeg-turbo": "→ libs/jpeg (self-built)",
    "libwebp":    "→ libs/webp (self-built)",
    "zlib":       "→ libs/zlib (self-built)",
    "sqlite3":    "→ libs/libsqlite3 (self-built)",
    "libxml2":    "→ excluded (Ladybird built-in XML parser)",
    "simdjson":   "→ excluded (Ladybird built-in JSON parser)",
    "simdutf":    "→ libunicode (Phase 3 replacement)",
    "libtommath": "→ excluded (Ladybird built-in BigInt)",
    "fast-float": "→ kept (header-only, required by AK)",
    "fmt":        "→ kept (required by AK formatting)",
    "cpptrace":   "→ excluded (optional, not available on RinOS)",
    "dbus":       "→ excluded (not applicable)",
    "pthread":    "→ RinOS libc pthreads",
    "mman":       "→ RinOS libc mmap",
    "tiff":       "→ excluded (TIFF format unsupported)"
  }
}
